{
  "name": "openly",
  "private": true,
  "license": "LicenseRef-Openly-Attribution-1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute openly-db --remote --file=src/schema.sql",
    "db:migrate:local": "wrangler d1 execute openly-db --local --file=src/schema.sql",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "wrangler": "^4",
    "typescript": "^5"
  }
}
